# ErgZone session token (Bearer). Da localStorage.SESSION_TOKEN nel browser admin.erg.zone loggato.
ERGZONE_SESSION_TOKEN=

# Track di default per le query/create workout (My Workouts).
ERGZONE_TRACK_ID=0e3a990f-d7b2-477a-ac32-16795f7a32e0

# Endpoint GraphQL (default produzione).
ERGZONE_ENDPOINT=https://production.erg.zone/api

# Abilita le mutation (create/update/delete). "false" => solo lettura.
ERGZONE_ALLOW_WRITE=true
