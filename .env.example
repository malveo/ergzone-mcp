# ErgZone session token (Bearer). From localStorage.SESSION_TOKEN in the logged-in admin.erg.zone browser.
ERGZONE_SESSION_TOKEN=

# Default track for queries / create workout (My Workouts).
ERGZONE_TRACK_ID=0e3a990f-d7b2-477a-ac32-16795f7a32e0

# GraphQL endpoint (default: production).
ERGZONE_ENDPOINT=https://production.erg.zone/api

# Enable mutations (create/update/delete). "false" => read-only.
ERGZONE_ALLOW_WRITE=true
