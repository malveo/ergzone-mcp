# --- Authentication: choose ONE ---

# Option A: paste a ready session token (from localStorage.SESSION_TOKEN on admin.erg.zone).
ERGZONE_SESSION_TOKEN=

# Option B: Concept2 Logbook credentials -> the server logs in headlessly and caches the token.
# No browser, no install. The token is cached under ~/.config/ergzone-mcp/ (chmod 600).
# Note: stores your Logbook password; see README for the security/ToS caveats.
ERGZONE_LOGBOOK_EMAIL=
ERGZONE_LOGBOOK_PASSWORD=

# --- Common ---

# Default track for queries / create workout.
# Leave empty to auto-detect your personal "My Workouts" track.
# Set only to target a specific ErgZone track ID.
ERGZONE_TRACK_ID=

# GraphQL endpoint (default: production).
ERGZONE_ENDPOINT=https://production.erg.zone/api

# Enable mutations (create/update/delete). "false" => read-only.
ERGZONE_ALLOW_WRITE=true
